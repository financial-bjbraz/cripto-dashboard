# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:4200,http://localhost:4201

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Connection URI — example: mongodb://host:port/dbname
MONGO_URI=mongodb://192.168.15.4:32771/bff_db

# ── Observability ─────────────────────────────────────────────────────────────
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Reliability ───────────────────────────────────────────────────────────────
# Request timeout in milliseconds (default: 10000)
REQUEST_TIMEOUT_MS=10000

# ── AWS Cognito ────────────────────────────────────────────────────────────────
# Cognito Hosted UI (Authorization Code + PKCE)
COGNITO_USER_POOL_ID=us-east-1_1jVdBHfqN
COGNITO_APP_CLIENT_ID=7kpe7t9iqpect9e3ljirjp2c39
COGNITO_REGION=us-east-1

# ── DFNS ───────────────────────────────────────────────────────────────────────
# Get these from DFNS dashboard (https://app.dfns.io)
DFNS_API_URL=https://api.dfns.ninja
DFNS_APP_ID=ap-XXXXXXXXXXXX
DFNS_SERVICE_ACCOUNT_TOKEN=eyJ...
DFNS_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----...
DFNS_ADMIN_WALLET_ID=wa-XXXXXXXXXXXX
DFNS_CONTRACT_ADDRESS=0x...

# ── Transactions ───────────────────────────────────────────────────────────────
# BRL threshold above which buy/sell transactions require admin approval
LARGE_TX_THRESHOLD=10000
